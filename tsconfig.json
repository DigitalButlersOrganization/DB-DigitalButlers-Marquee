{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		// "declaration": true,
		"useDefineForClassFields": true,
		"lib": ["ESNext", "DOM"],
		"strict": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"skipLibCheck": true,
		"importHelpers": true, // Позволяет использовать вспомогательные функции из tslib
		"allowSyntheticDefaultImports": true, // Разрешает импорт из модулей без дефолтного экспорта
		"forceConsistentCasingInFileNames": true,
		// Требует согласованности регистра в именах файлов
		"outDir": "./dist",
		"rootDir": "./src"
	},
	"include": ["./src/**/*.ts"]
}
